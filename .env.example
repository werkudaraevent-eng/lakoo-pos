# Database (Supabase PostgreSQL connection string)
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# JWT Secret (minimum 32 characters — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
POS_JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# Server port (Railway sets this automatically, don't set manually)
# PORT=3001

# Environment (set to 'production' on Railway for sanitized error messages)
# NODE_ENV=production
